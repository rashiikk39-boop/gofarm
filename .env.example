# =============================================================================
#  GoFarm — Environment template
#  Copy to `.env.local` for development. NEVER commit real secrets.
# =============================================================================

# ---- App ---------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development
# Comma-separated list of additional allowed origins for CSRF protection.
APP_ALLOWED_ORIGINS=

# Premium / purchase upsell URL used by `PremiumFeature`, `PremiumDialog`,
# `PurchaseFloatingButton`, and the header "Buy" badge.
# NEXT_PUBLIC_PURCHASE_CODE_URL=https://buymeacoffee.com/reactbd/e/484104

# ---- Sanity ------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-09
SANITY_API_TOKEN=                    # write token (server only) — REQUIRED
SANITY_API_READ_TOKEN=               # read token  (server only, optional)

# ---- Firebase (client) -------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID= 
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Firebase Admin (server) -------------------------------------------------
# From Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_CLIENT_EMAIL=
# Paste the full PEM in one line, with literal "\n" between sections
FIREBASE_PRIVATE_KEY=

# ---- Roles -------------------------------------------------------------------
# Comma-separated. Used to seed Firebase custom claims on first login.
ADMIN_EMAILS=admin@example.com
# Optional, additive to ADMIN_EMAILS. Public-safe.
NEXT_PUBLIC_ADMIN_EMAIL=

# ---- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- SSLCommerz (Bangladesh) -------------------------------------------------
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

# ---- Email -------------------------------------------------------------------
# Gmail SMTP. Use EITHER an App Password (preferred) OR OAuth2.
# 1) App Password: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# 2) OAuth2 fallback (refresh tokens issued in "Testing" mode expire in 7 days)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# From-address for outbound mail
SENDER_EMAIL_ADDRESS=

# ---- Maps --------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Analytics ---------------------------------------------------------------
# GA4 Measurement Protocol (server-side purchase / refund tracking)
GA4_MEASUREMENT_ID=                  # G-XXXXXXX (same as NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID)
GA4_API_SECRET=                      # GA4 → Admin → Data Streams → Web → Measurement Protocol API secrets

# ---- Tax / Loyalty -----------------------------------------------------------
TAX_AMOUNT=0.00
REWARD_POINTS_THRESHOLD=3000
REWARD_POINTS_AMOUNT=5
LOYALTY_POINTS_ORDER_THRESHOLD=5
LOYALTY_POINTS_AMOUNT=100

# ---- Company info (public) ---------------------------------------------------
NEXT_PUBLIC_COMPANY_NAME=GoFarm
NEXT_PUBLIC_COMPANY_EMAIL=support@example.com
NEXT_PUBLIC_COMPANY_PHONE=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_COMPANY_CITY=
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKDAY=
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKEND=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SALES_EMAIL=
NEXT_PUBLIC_CONTACT_RESPONSE_TIME=
NEXT_PUBLIC_QUICK_RESPONSE_TIME=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_COMPANY_DESCRIPTION=
NEXT_PUBLIC_COPYRIGHT_TEXT=
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy
NEXT_PUBLIC_TERMS_URL=/terms
